generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Log {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  type      String // error, info, warn
  topic     String // environment, user, etc
  message   String
  meta      String
}
